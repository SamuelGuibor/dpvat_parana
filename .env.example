# ============================================================================
# Paraná Seguros — variáveis de ambiente
# Copie para .env e preencha. Obrigatórias marcadas com [OBRIGATÓRIA].
# ============================================================================

# ---------- Banco de dados (Neon PostgreSQL) [OBRIGATÓRIA] ----------
DATABASE_URL="postgresql://user:pass@host/neondb?sslmode=require"

# ---------- NextAuth [OBRIGATÓRIA] ----------
# Segredo do JWT de sessão (gere com: openssl rand -base64 32).
# Obs.: o middleware aceita NEXT_AUTH_SECRET como fallback legado — prefira NEXTAUTH_SECRET.
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Login social Google (opcional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ---------- AWS S3 (uploads: documentos, avatares, mídia do WhatsApp) [OBRIGATÓRIA] ----------
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET_NAME=""

# ---------- WhatsApp Cloud API (Meta) ----------
WHATSAPP_TOKEN=""              # token permanente do app da Meta
WHATSAPP_PHONE_NUMBER_ID=""    # id do número no WhatsApp Business
WHATSAPP_WABA_ID=""            # id da conta WhatsApp Business (templates)
WHATSAPP_APP_SECRET=""         # valida a assinatura HMAC do webhook
WHATSAPP_VERIFY_TOKEN=""       # token de verificação do webhook (você escolhe)
WHATSAPP_API_VERSION="v20.0"
WHATSAPP_STATUS_TEMPLATE=""    # template aprovado p/ avisos fora da janela de 24h
WHATSAPP_SYSTEM_COOLDOWN_HOURS="20"
WHATSAPP_TEST_NUMBERS=""       # números de teste separados por vírgula

# ---------- Meta Conversions API (rastreio de anúncios → CRM) ----------
META_DATASET_ID=""             # dataset "Novo CRM"
META_CONVERSIONS_TOKEN=""
META_TEST_EVENT_CODE=""        # só em teste (ex.: TEST32813); vazio em produção

# ---------- Cron da Vercel [OBRIGATÓRIA em produção] ----------
CRON_SECRET=""                 # Authorization: Bearer <CRON_SECRET>

# ---------- Chat interno em tempo real (relay SSE no Railway) ----------
CHAT_RELAY_URL=""
CHAT_RELAY_SECRET=""

# ---------- Gestão / permissões ----------
MANAGER_EMAILS=""              # e-mails com Visão do Gestor (fallback; o normal é dar a permissão pela tela de Equipe)
SECTOR_ADMIN_IDS=""            # ids de admins de setor (legado)
CHATBOT_DASHBOARD_EMAILS=""    # acesso ao painel do chatbot

# ---------- Chatbot WhatsApp (projeto separado D:\Chatbot_whatsapp) ----------
CHATBOT_URL=""
CHATBOT_URL_STAGING=""
CHATBOT_SECRET=""
BOT_WEBHOOK_URL=""
BOT_WEBHOOK_SECRET=""

# ---------- Microserviço docx-converter (D:\docx-converter — roteiros/IA e DOCX→PDF) ----------
DOCX_CONVERTER_URL=""
CONVERTER_API_KEY=""

# ---------- IA (Gemini — assistente interno e recursos de IA) ----------
GOOGLE_API_KEY=""
WINDMILL_TOKEN=""              # jobs do assistente (Windmill)

# ---------- Discord (notificações internas) ----------
DISCORD_WEBHOOK_URL=""             # geral
DISCORD_WEBHOOK_URL_ERRORS=""      # erros críticos (report-error.ts); cai no geral se vazio
DISCORD_WEBHOOK_URL_JURIDICO=""
DISCORD_WEBHOOK_URL_PRONTUARIO=""
DISCORD_WEBHOOK_URL_WHATSAPP=""
DISCORD_TOKEN=""
DISCORD_LOG_CHANNEL=""
DISCORD_POINT_CHANNEL=""

# ---------- Recuperação de senha (SMS + e-mail via AWS) ----------
# SMS: usa AWS SNS com as MESMAS credenciais AWS_* do S3 (o IAM user precisa
# da permissão sns:Publish e a conta precisa estar liberada para SMS).
SNS_SMS_SENDER_ID="ParanaSeg"    # remetente exibido no SMS (onde suportado)
# E-mail: AWS SES — verifique o domínio/remetente no painel do SES e defina:
SES_FROM_EMAIL=""                # ex.: nao-responda@segurosparana.com.br
SES_REGION=""                    # opcional; usa AWS_REGION se vazio

# Twilio (opcional — 2º fallback de SMS depois do SNS; WhatsApp é o último)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""            # ex.: +15017122661 (ou use o Messaging Service abaixo)
TWILIO_MESSAGING_SERVICE_SID=""

# ---------- Integrações diversas ----------
TRELLO_KEY=""
TRELLO_TOKEN=""
ALLOWED_ORIGIN=""               # CORS de rotas expostas
