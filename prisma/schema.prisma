generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SavedPrompt {
  id        String   @id @default(cuid())
  title     String
  content   String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id                  String         @id @default(cuid())
  name                String?
  cpf                 String?
  email               String         @unique
  password            String?
  rua                 String?
  bairro              String?
  numero              String?
  cep                 String?
  image               String?
  role                String         @default("Filtro de Cartões")
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  emailVerified       DateTime?
  cidade              String?
  estado              String?
  estado_civil        String?
  nacionalidade       String?
  nome_mae            String?
  profissao           String?
  rg                  String?
  status              String?
  telefone            String?
  atendimento_via     String?
  hospital            String?
  lesoes              String?
  outro_hospital      String?
  cpf_res             String?
  estado_civil_res    String?
  nome_res            String?
  profissao_res       String?
  rg_res              String?
  statusStartedAt     DateTime?
  obs                 String?
  service             String?
  otherObs            String?
  fixed               Boolean?       @default(true)
  roleFixed           String?        @default("Acompanhamento de fluxo 1")
  labelId             String?
  apto                Boolean        @default(false)
  data_nasc           String?
  data_acidente       String?
  senha_inss          String?
  cardNumber          Int?           @unique
  afastadoAte         DateTime?
  afastadoNotificado  Boolean        @default(false)
  lastSeenAt          DateTime?
  telefone_secundario String?
  rede_social         String?
  archiveStatus       String?
  archivedAt          DateTime?
  accounts            Account[]
  commentsAsAuthor    Comment[]      @relation("CommentAuthor")
  commentsOnCard      Comment[]      @relation("UserComments")
  document            Document[]
  notifications       Notification[] @relation("UserNotifications")
  processes           Process[]
  sessions            Session[]
  label               Label?         @relation("UserLabel", fields: [labelId], references: [id])
  chatMessages        ChatMessage[]  @relation("ChatAuthor")
  logs                Log[]          @relation("UserLogs")
}

model ChatMessage {
  id         String    @id @default(cuid())
  body       String
  authorId   String
  authorName String
  channelId  String
  createdAt  DateTime  @default(now())
  editedAt   DateTime?
  // Soft-delete estilo WhatsApp: quando preenchido, renderiza "mensagem apagada".
  deletedAt  DateTime?
  // Resposta a outra mensagem (reply). Guarda também um snapshot do original
  // (autor + trecho) para render estável mesmo se o pai for alterado/apagado.
  replyToId       String?
  replyToAuthor   String?
  replyToBody     String?
  author     User      @relation("ChatAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  replyTo    ChatMessage?  @relation("ChatReply", fields: [replyToId], references: [id], onDelete: SetNull)
  replies    ChatMessage[] @relation("ChatReply")

  @@index([channelId, createdAt])
  @@map("chat_messages")
}

model ChatRead {
  userId     String
  channelId  String
  lastReadAt DateTime @default(now())

  @@id([userId, channelId])
  @@map("chat_reads")
}

// Canal customizado (privado por natureza): só os membros veem/escrevem.
// Os canais "general" e "dm:*" NÃO têm linha aqui — são tratados por convenção.
model ChatChannel {
  id          String              @id @default(cuid())
  name        String
  createdById String
  createdAt   DateTime            @default(now())
  members     ChatChannelMember[]

  @@map("chat_channels")
}

model ChatChannelMember {
  channelId String
  userId    String
  channel   ChatChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@id([channelId, userId])
  @@index([userId])
  @@map("chat_channel_members")
}

model Process {
  id                  String     @id @default(cuid())
  userId              String
  role                String?
  statusStartedAt     DateTime?
  atendimento_via     String?
  hospital            String?
  outro_hospital      String?
  lesoes              String?
  type                String?
  observacao          String?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  status              String?
  bairro              String?
  cep                 String?
  cidade              String?
  cpf                 String?
  cpf_res             String?
  email               String?
  emailVerified       DateTime?
  estado              String?
  estado_civil        String?
  estado_civil_res    String?
  image               String?
  nacionalidade       String?
  name                String?
  nome_mae            String?
  nome_res            String?
  numero              String?
  profissao           String?
  profissao_res       String?
  rg                  String?
  rg_res              String?
  rua                 String?
  telefone            String?
  otherObs            String?
  service             String?
  fixed               Boolean?   @default(true)
  roleFixed           String?    @default("Acompanhamento de fluxo 1")
  labelId             String?
  data_nasc           String?
  data_acidente       String?
  senha_inss          String?
  cardNumber          Int?       @unique
  afastadoAte         DateTime?
  afastadoNotificado  Boolean    @default(false)
  telefone_secundario String?
  rede_social         String?
  archiveStatus       String?
  archivedAt          DateTime?
  commentsOnProcess   Comment[]  @relation("ProcessComments")
  documents           Document[]
  label               Label?     @relation("ProcessLabel", fields: [labelId], references: [id])
  user                User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs                Log[]      @relation("ProcessLogs")
}

model Label {
  id            String       @id @default(cuid())
  name          String       @unique
  color         String
  order         Int          @default(0)
  timeLimitDays Int?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  processes     Process[]    @relation("ProcessLabel")
  users         User[]       @relation("UserLabel")
  automations   Automation[]
}

model Automation {
  id             String   @id @default(cuid())
  name           String
  isActive       Boolean  @default(true)
  triggerLabelId String
  cardType       String   @default("both")
  conditionLogic String   @default("AND")
  conditions     Json     @default("[]")
  actions        Json     @default("[]")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  triggerLabel   Label    @relation(fields: [triggerLabelId], references: [id], onDelete: Cascade)

  @@map("automations")
}

model Comment {
  id         String   @id @default(cuid())
  text       String
  authorId   String?
  authorName String
  userId     String?
  processId  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  targetName String
  author     User?    @relation("CommentAuthor", fields: [authorId], references: [id])
  process    Process? @relation("ProcessComments", fields: [processId], references: [id])
  user       User?    @relation("UserComments", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([processId])
  @@index([authorId])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model Message {
  id               String       @id @default(cuid())
  titulo           String
  role             String       @default("USER")
  createdAt        DateTime?    @default(now())
  updatedAt        DateTime?    @updatedAt
  multipleMessages SubMessage[]
}

model SubMessage {
  id        String    @id @default(cuid())
  conteudo  String
  messageId String
  mediaType String?
  mediaUrl  String?
  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt
  message   Message   @relation(fields: [messageId], references: [id], onDelete: Cascade)
}

model Document {
  id         String    @id @default(uuid())
  userId     String
  key        String
  name       String
  uploadedAt DateTime  @default(now())
  processId  String?
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt
  process    Process?  @relation(fields: [processId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Contact {
  id        String    @id @default(uuid())
  name      String
  number    String
  desc      String?
  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt
}

model Notification {
  id          String   @id @default(cuid())
  recipientId String
  authorId    String
  authorName  String
  message     String
  commentId   String?
  userId      String?
  processId   String?
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())
  targetName  String
  recipient   User     @relation("UserNotifications", fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([recipientId])
}

model Log {
  id         String   @id @default(cuid())
  action     String
  message    String
  authorId   String
  authorName String
  userId     String?
  processId  String?
  metadata   Json?
  createdAt  DateTime @default(now())
  process    Process? @relation("ProcessLogs", fields: [processId], references: [id], onDelete: Cascade)
  user       User?    @relation("UserLogs", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([processId])
  @@map("logs")
}

model Botconversa {
  id        String    @id @default(cuid())
  nome      String
  evento    String
  telefone  String
  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt
}

model Discord {
  id        String    @id @default(cuid())
  message   String
  channelId String
  executeAt DateTime
  sent      Boolean   @default(false)
  nome      String?
  telefone  String?
  evento    String?
  hours     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt
  firstSent Boolean   @default(false)

  @@map("discord")
}

model WorkSession {
  id         String    @id @default(cuid())
  userId     String
  discordId  String
  date       String
  startedAt  DateTime?
  pausedAt   DateTime?
  resumedAt  DateTime?
  finishedAt DateTime?
  isActive   Boolean   @default(false)
  isPaused   Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([discordId, date])
}

model AdminChecklistItem {
  id        String   @id @default(cuid())
  processId String?
  userId    String?
  text      String
  checked   Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([processId])
  @@index([userId])
  @@map("admin_checklist_items")
}

model Instruction {
  id          String            @id @default(cuid())
  title       String
  description String?
  text        String?
  color       String            @default("amber")
  tags        String[]          @default([])
  folderName  String            @unique
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  files       InstructionFile[]

  @@map("instructions")
}

model InstructionFile {
  id            String      @id @default(cuid())
  instructionId String
  name          String
  key           String
  size          String?
  type          String?
  uploadedAt    DateTime    @default(now())
  instruction   Instruction @relation(fields: [instructionId], references: [id], onDelete: Cascade)

  @@index([instructionId])
  @@map("instruction_files")
}
