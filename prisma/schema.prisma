generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SavedPrompt {
  id        String   @id @default(cuid())
  title     String
  content   String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Config das mensagens automáticas de PROGRESSÃO DE STATUS enviadas ao cliente
// no WhatsApp. Uma linha por (serviceKey, status) — global, não por card.
// customText nulo = usa o texto padrão do sistema; enabled=false = não envia.
// serviceKey é normalizado: "DPVAT" | "INSS" | "GENERIC".
model StatusMessageConfig {
  id         String   @id @default(cuid())
  serviceKey String
  status     String
  enabled    Boolean  @default(true)
  customText String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([serviceKey, status])
  @@map("status_message_configs")
}

model User {
  id                  String         @id @default(cuid())
  name                String?
  cpf                 String?
  email               String         @unique
  password            String?
  rua                 String?
  bairro              String?
  numero              String?
  cep                 String?
  image               String?
  role                String         @default("Filtro de Cartões")
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  emailVerified       DateTime?
  cidade              String?
  estado              String?
  estado_civil        String?
  nacionalidade       String?
  nome_mae            String?
  profissao           String?
  rg                  String?
  status              String?
  telefone            String?
  atendimento_via     String?
  hospital            String?
  lesoes              String?
  outro_hospital      String?
  cpf_res             String?
  estado_civil_res    String?
  nome_res            String?
  profissao_res       String?
  rg_res              String?
  statusStartedAt     DateTime?
  obs                 String?
  service             String?
  otherObs            String?
  fixed               Boolean?       @default(true)
  roleFixed           String?        @default("Acompanhamento de fluxo 1")
  labelId             String?
  apto                Boolean        @default(false)
  data_nasc           String?
  data_acidente       String?
  senha_inss          String?
  cardNumber          Int?           @unique
  afastadoAte         DateTime?
  afastadoNotificado  Boolean        @default(false)
  lastSeenAt          DateTime?
  telefone_secundario String?
  rede_social         String?
  archiveStatus       String?
  archivedAt          DateTime?
  sectorId            String?
  sector              Sector?        @relation("UserSector", fields: [sectorId], references: [id], onDelete: SetNull)
  accounts            Account[]
  commentsAsAuthor    Comment[]      @relation("CommentAuthor")
  commentsOnCard      Comment[]      @relation("UserComments")
  document            Document[]
  notifications       Notification[] @relation("UserNotifications")
  processes           Process[]
  sessions            Session[]
  label               Label?         @relation("UserLabel", fields: [labelId], references: [id])
  chatMessages        ChatMessage[]  @relation("ChatAuthor")
  chatReactions       ChatReaction[] @relation("ReactionAuthor")
  logs                Log[]          @relation("UserLogs")
}

// Setor/função da pessoa (Comercial, Financeiro, Desenvolvedor…). Diferente de
// `role` (nível de acesso): o setor é a "área" da pessoa, usada para @menção no
// chat, tag no perfil e dashboard de rendimento por setor. Quem pode gerir os
// setores é controlado por SECTOR_ADMIN_IDS (ver app/_shared/lib/sector-admin.ts).
model Sector {
  id        String   @id @default(cuid())
  name      String   @unique
  // slug em minúsculas, sem espaço — é o que se digita no @menção (@comercial).
  slug      String   @unique
  color     String   @default("#3b82f6")
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]   @relation("UserSector")

  @@map("sectors")
}

model ChatMessage {
  id             String         @id @default(cuid())
  body           String
  authorId       String
  authorName     String
  channelId      String
  createdAt      DateTime       @default(now())
  editedAt       DateTime?
  // Soft-delete estilo WhatsApp: quando preenchido, renderiza "mensagem apagada".
  deletedAt      DateTime?
  // Resposta a outra mensagem (reply). Guarda também um snapshot do original
  // (autor + trecho) para render estável mesmo se o pai for alterado/apagado.
  replyToId      String?
  replyToAuthor  String?
  replyToBody    String?
  // Anexo opcional (foto/vídeo/áudio/arquivo). A key aponta pro S3 (prefixo
  // "chat/"); o tipo MIME decide o render inline (imagem/vídeo/áudio) ou link.
  attachmentKey  String?
  attachmentName String?
  attachmentType String?
  author         User           @relation("ChatAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  replyTo        ChatMessage?   @relation("ChatReply", fields: [replyToId], references: [id], onDelete: SetNull)
  replies        ChatMessage[]  @relation("ChatReply")
  reactions      ChatReaction[]

  @@index([channelId, createdAt])
  @@map("chat_messages")
}

// Reação (emoji) de uma pessoa numa mensagem. Unicidade por (msg, user, emoji)
// permite alternar (toggle): reagir de novo com o mesmo emoji remove.
model ChatReaction {
  id        String      @id @default(cuid())
  messageId String
  userId    String
  userName  String
  emoji     String
  createdAt DateTime    @default(now())
  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User        @relation("ReactionAuthor", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
  @@map("chat_reactions")
}

model ChatRead {
  userId     String
  channelId  String
  lastReadAt DateTime @default(now())

  @@id([userId, channelId])
  @@map("chat_reads")
}

// Canal customizado (privado por natureza): só os membros veem/escrevem.
// Os canais "general" e "dm:*" NÃO têm linha aqui — são tratados por convenção.
model ChatChannel {
  id          String              @id @default(cuid())
  name        String
  createdById String
  createdAt   DateTime            @default(now())
  members     ChatChannelMember[]

  @@map("chat_channels")
}

model ChatChannelMember {
  channelId String
  userId    String
  channel   ChatChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@id([channelId, userId])
  @@index([userId])
  @@map("chat_channel_members")
}

model Process {
  id                  String     @id @default(cuid())
  userId              String
  role                String?
  statusStartedAt     DateTime?
  atendimento_via     String?
  hospital            String?
  outro_hospital      String?
  lesoes              String?
  type                String?
  observacao          String?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  status              String?
  bairro              String?
  cep                 String?
  cidade              String?
  cpf                 String?
  cpf_res             String?
  email               String?
  emailVerified       DateTime?
  estado              String?
  estado_civil        String?
  estado_civil_res    String?
  image               String?
  nacionalidade       String?
  name                String?
  nome_mae            String?
  nome_res            String?
  numero              String?
  profissao           String?
  profissao_res       String?
  rg                  String?
  rg_res              String?
  rua                 String?
  telefone            String?
  otherObs            String?
  service             String?
  fixed               Boolean?   @default(true)
  roleFixed           String?    @default("Acompanhamento de fluxo 1")
  labelId             String?
  data_nasc           String?
  data_acidente       String?
  senha_inss          String?
  cardNumber          Int?       @unique
  afastadoAte         DateTime?
  afastadoNotificado  Boolean    @default(false)
  telefone_secundario String?
  rede_social         String?
  archiveStatus       String?
  archivedAt          DateTime?
  commentsOnProcess   Comment[]  @relation("ProcessComments")
  documents           Document[]
  label               Label?     @relation("ProcessLabel", fields: [labelId], references: [id])
  user                User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs                Log[]      @relation("ProcessLogs")
}

model Label {
  id            String       @id @default(cuid())
  name          String       @unique
  color         String
  order         Int          @default(0)
  timeLimitDays Int?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  processes     Process[]    @relation("ProcessLabel")
  users         User[]       @relation("UserLabel")
  automations   Automation[]
}

model Automation {
  id             String   @id @default(cuid())
  name           String
  isActive       Boolean  @default(true)
  triggerLabelId String
  cardType       String   @default("both")
  conditionLogic String   @default("AND")
  conditions     Json     @default("[]")
  actions        Json     @default("[]")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  triggerLabel   Label    @relation(fields: [triggerLabelId], references: [id], onDelete: Cascade)

  @@map("automations")
}

model Comment {
  id         String   @id @default(cuid())
  text       String
  authorId   String?
  authorName String
  userId     String?
  processId  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  targetName String
  author     User?    @relation("CommentAuthor", fields: [authorId], references: [id])
  process    Process? @relation("ProcessComments", fields: [processId], references: [id])
  user       User?    @relation("UserComments", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([processId])
  @@index([authorId])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model Message {
  id               String       @id @default(cuid())
  titulo           String
  role             String       @default("USER")
  createdAt        DateTime?    @default(now())
  updatedAt        DateTime?    @updatedAt
  multipleMessages SubMessage[]
}

model SubMessage {
  id        String    @id @default(cuid())
  conteudo  String
  messageId String
  mediaType String?
  mediaUrl  String?
  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt
  message   Message   @relation(fields: [messageId], references: [id], onDelete: Cascade)
}

model Document {
  id         String    @id @default(uuid())
  userId     String
  key        String
  name       String
  uploadedAt DateTime  @default(now())
  processId  String?
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt
  process    Process?  @relation(fields: [processId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Contact {
  id        String    @id @default(uuid())
  name      String
  number    String
  desc      String?
  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt
}

model Notification {
  id          String   @id @default(cuid())
  recipientId String
  authorId    String
  authorName  String
  message     String
  commentId   String?
  userId      String?
  processId   String?
  // Notificações de WhatsApp (bot/handoff): clicar abre direto a conversa.
  contactId   String?
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())
  targetName  String
  recipient   User     @relation("UserNotifications", fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([recipientId])
}

model Log {
  id         String   @id @default(cuid())
  action     String
  message    String
  authorId   String
  authorName String
  userId     String?
  processId  String?
  metadata   Json?
  createdAt  DateTime @default(now())
  process    Process? @relation("ProcessLogs", fields: [processId], references: [id], onDelete: Cascade)
  user       User?    @relation("UserLogs", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([processId])
  @@map("logs")
}

// ============ WhatsApp Cloud API (Meta oficial) ============
// Contato = número de telefone único. Pode ser vinculado manualmente a um
// User/Process já cadastrado (userId/processId são referências soltas, sem FK,
// para não criar cascade com dados de clientes).
model WhatsAppContact {
  id             String                @id @default(cuid())
  phone          String                @unique // E.164, ex: 5541999999999
  name           String?
  userId         String?
  processId      String?
  optedOut       Boolean               @default(false)
  // Opt-in documentado (exigência anti-spam da Meta): quando e como o cliente
  // aceitou receber mensagens. Preenchido automaticamente na 1ª mensagem
  // recebida ("inbound"). Sem opt-in, envio proativo fora da janela de 24h é
  // pulado (dentro da janela sempre pode, pois o cliente acabou de escrever).
  optedInAt      DateTime?
  optInSource    String? // inbound | manual
  // Rascunho da ficha do cliente preenchida no atendimento, quando o contato
  // ainda não tem User vinculado. Vira User no "Adicionar cliente".
  clientDraft    Json?
  // Documentos pessoais anexados na ficha antes do contato virar cliente:
  // [{ key, name, uploadedAt }]. Migram para Document real no "Adicionar cliente".
  draftDocuments Json?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  conversation   WhatsAppConversation?
  messages       WhatsAppMessage[]

  @@map("whatsapp_contacts")
}

model WhatsAppConversation {
  id              String                     @id @default(cuid())
  contactId       String                     @unique
  status          String                     @default("bot") // bot | queued | human | closed
  assignedToId    String?
  // Só relevante quando status="closed": null/false = não qualificada
  // (default), true = qualificada. Decidido no botão de encerrar ou pela IA.
  qualified       Boolean?
  // Desfecho do atendimento (categoria de encerramento decidida pela IA ou
  // pelo atendente): qualificado | nao_qualificado | perguntas | novo_acidente
  // | transferido. Null enquanto em andamento.
  closeCategory   String?
  // Cérebro da IA (persistido por conversa; o microserviço é stateless):
  botMemory       String? // ficha de fatos extraída pela IA ("Nome: João | Cidade: Curitiba")
  botState        String? // etapa da conversa (triagem_seguro, coleta_cpf...)
  botFailCount    Int                        @default(0) // "não entendi" seguidos; 2 → escala pra humano
  botNudge30At    DateTime? // "ainda está aí?" enviado (silêncio de 30min)
  botNudge24At    DateTime? // follow-up de ~24h enviado
  // Urgência detectada pela IA — destaca a conversa no inbox até um atendente
  // assumir ou encerrar.
  urgent          Boolean                    @default(false)
  // SLA da fila de espera: quando entrou na fila e quando o último alerta de
  // "cliente esperando demais" foi disparado pelo cron (evita spam).
  queuedAt        DateTime?
  queueAlertAt    DateTime?
  // Último alerta de FALHA DE ENTREGA (status "failed" da Meta ou mensagem
  // parada em "sent" sem "delivered" = provável bloqueio/número errado) —
  // debounce para não repetir o aviso. O envio ao número NÃO é bloqueado:
  // a equipe é avisada para verificar número/bloqueio/janela de 24h.
  deliveryAlertAt DateTime?
  lastMessageAt   DateTime                   @default(now())
  // Legado: marcador global de leitura (mantido como fallback na migração
  // para leitura POR ATENDENTE — ver WhatsAppConversationRead).
  lastReadAt      DateTime?
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt
  contact         WhatsAppContact            @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tags            WhatsAppConversationTag[]
  reads           WhatsAppConversationRead[]

  @@index([status])
  @@index([assignedToId])
  @@map("whatsapp_conversations")
}

// Leitura POR ATENDENTE: cada membro da equipe tem seu próprio "até onde li"
// em cada conversa — abrir a conversa não zera o não-lido dos colegas.
model WhatsAppConversationRead {
  conversationId String
  userId         String
  lastReadAt     DateTime             @default(now())
  conversation   WhatsAppConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@id([conversationId, userId])
  @@map("whatsapp_conversation_reads")
}

// Respostas rápidas (snippets) do atendimento — textos curtos reutilizáveis
// que o atendente insere no composer com um clique.
model WhatsAppQuickReply {
  id        String   @id @default(cuid())
  title     String   @unique
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("whatsapp_quick_replies")
}

// Tags livres pra organizar conversas (ex.: "Urgente", "VIP", "Recontato").
model WhatsAppTag {
  id            String                    @id @default(cuid())
  name          String                    @unique
  color         String                    @default("#10b981")
  createdAt     DateTime                  @default(now())
  conversations WhatsAppConversationTag[]

  @@map("whatsapp_tags")
}

model WhatsAppConversationTag {
  conversationId String
  tagId          String
  conversation   WhatsAppConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  tag            WhatsAppTag          @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([conversationId, tagId])
  @@map("whatsapp_conversation_tags")
}

model WhatsAppMessage {
  id               String          @id @default(cuid())
  contactId        String
  waMessageId      String?         @unique // id da Meta; evita duplicar em retry de webhook
  direction        String // in | out
  body             String?
  mediaKey         String? // chave no S3 (mesmo bucket dos documentos)
  mediaType        String?
  status           String          @default("sent") // sent | delivered | read | failed
  sentByBot        Boolean         @default(false)
  // Origem de mensagem PROATIVA do sistema ("automation" | "progress").
  // Null em respostas do bot conversacional e de atendentes. Usado pelo cap
  // de frequência anti-spam (máx. 1 proativa por contato a cada N horas).
  systemSource     String?
  authorId         String? // funcionário que enviou (se humano)
  internal         Boolean         @default(false) // nota interna, não vai pro cliente
  // Edição/exclusão LOCAIS (a Cloud API não propaga pro celular do cliente).
  editedAt         DateTime?
  deletedAt        DateTime?
  // Resposta (quote): id da mensagem respondida + snapshot pro render estável.
  replyToId        String?
  replyToBody      String?
  replyToDirection String?
  createdAt        DateTime        @default(now())
  contact          WhatsAppContact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId, createdAt])
  @@map("whatsapp_messages")
}

// Fluxo de mensagens pré-setadas do atendimento (sequência de textos com
// delay entre os envios). steps = [{ body: string, delayMs: number }].
model WhatsAppFlow {
  id          String   @id @default(cuid())
  name        String   @unique
  // Descrição do fluxo em linguagem natural — a IA lê isto para decidir QUANDO
  // este fluxo se encaixa na situação do cliente e dispará-lo automaticamente.
  description String?
  steps       Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("whatsapp_flows")
}

model WhatsAppTemplate {
  id          String  @id @default(cuid())
  name        String  @unique // nome aprovado na Meta
  language    String  @default("pt_BR")
  bodyVars    Int     @default(0)
  // Texto de referência com {{1}} {{2}}... só pra equipe saber o que digitar
  // em cada variável — não é enviado à Meta (ela já tem o template aprovado).
  bodyPreview String?

  @@map("whatsapp_templates")
}

model Botconversa {
  id        String    @id @default(cuid())
  nome      String
  evento    String
  telefone  String
  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt
}

model Discord {
  id        String    @id @default(cuid())
  message   String
  channelId String
  executeAt DateTime
  sent      Boolean   @default(false)
  nome      String?
  telefone  String?
  evento    String?
  hours     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt
  firstSent Boolean   @default(false)

  @@map("discord")
}

model WorkSession {
  id         String    @id @default(cuid())
  userId     String
  discordId  String
  date       String
  startedAt  DateTime?
  pausedAt   DateTime?
  resumedAt  DateTime?
  finishedAt DateTime?
  isActive   Boolean   @default(false)
  isPaused   Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([discordId, date])
}

model AdminChecklistItem {
  id        String   @id @default(cuid())
  processId String?
  userId    String?
  text      String
  // Agrupamento visual (COMERCIAL, ADM, MÉDICO…). Null = grupo "Outros".
  section   String?
  checked   Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([processId])
  @@index([userId])
  @@map("admin_checklist_items")
}

model Instruction {
  id          String            @id @default(cuid())
  title       String
  description String?
  text        String?
  color       String            @default("amber")
  tags        String[]          @default([])
  folderName  String            @unique
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  files       InstructionFile[]

  @@map("instructions")
}

model InstructionFile {
  id            String      @id @default(cuid())
  instructionId String
  name          String
  key           String
  size          String?
  type          String?
  uploadedAt    DateTime    @default(now())
  instruction   Instruction @relation(fields: [instructionId], references: [id], onDelete: Cascade)

  @@index([instructionId])
  @@map("instruction_files")
}
