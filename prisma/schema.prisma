generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SavedPrompt {
  id        String   @id @default(cuid())
  title     String
  content   String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id               String         @id @default(cuid())
  name             String?
  cpf              String?
  data_nasc        String?
  email            String         @unique
  password         String?
  rua              String?
  bairro           String?
  numero           String?
  cep              String?
  image            String?
  role             String         @default("Filtro de Cartões")
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  emailVerified    DateTime?
  cidade           String?
  estado           String?
  estado_civil     String?
  nacionalidade    String?
  nome_mae         String?
  profissao        String?
  rg               String?
  status           String?
  telefone         String?
  telefone_secundario String?
  rede_social         String?
  atendimento_via  String?
  data_acidente    String?
  hospital         String?
  lesoes           String?
  outro_hospital   String?
  cpf_res          String?
  estado_civil_res String?
  nome_res         String?
  profissao_res    String?
  rg_res           String?
  statusStartedAt  DateTime?
  obs              String?
  service          String?
  otherObs         String?
  fixed            Boolean?       @default(true)
  roleFixed        String?        @default("Acompanhamento de fluxo 1")
  labelId          String?
  label            Label?  @relation("UserLabel", fields: [labelId], references: [id])
  apto             Boolean        @default(false)
  senha_inss       String?
  cardNumber       Int?           @unique
  afastadoAte         DateTime?
  afastadoNotificado  Boolean      @default(false)
  lastSeenAt       DateTime?


  accounts         Account[]
  commentsAsAuthor Comment[]      @relation("CommentAuthor")
  commentsOnCard   Comment[]      @relation("UserComments")
  document         Document[]
  notifications    Notification[] @relation("UserNotifications")
  processes        Process[]
  sessions         Session[]
  logs             Log[]          @relation("UserLogs")
}

model Process {
  id                String     @id @default(cuid())
  userId            String
  role              String?
  statusStartedAt   DateTime?
  data_acidente     String?
  atendimento_via   String?
  hospital          String?
  outro_hospital    String?
  lesoes            String?
  type              String?
  observacao        String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  status            String?
  bairro            String?
  cep               String?
  cidade            String?
  cpf               String?
  cpf_res           String?
  data_nasc         String?
  email             String?
  emailVerified     DateTime?
  estado            String?
  estado_civil      String?
  estado_civil_res  String?
  image             String?
  nacionalidade     String?
  name              String?
  nome_mae          String?
  nome_res          String?
  numero            String?
  profissao         String?
  profissao_res     String?
  rg                String?
  rg_res            String?
  rua               String?
  telefone          String?
  telefone_secundario String?
  rede_social         String?
  otherObs          String?
  service           String?
  fixed             Boolean?   @default(true)
  roleFixed         String?    @default("Acompanhamento de fluxo 1")
  labelId           String?
  label             Label?     @relation("ProcessLabel", fields: [labelId], references: [id])
  senha_inss        String?
  cardNumber        Int?       @unique
  afastadoAte         DateTime?
  afastadoNotificado  Boolean    @default(false)

  commentsOnProcess Comment[]  @relation("ProcessComments")
  documents         Document[]
  logs              Log[]      @relation("ProcessLogs")
  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Label {
  id            String       @id @default(cuid())
  name          String       @unique
  color         String
  order         Int          @default(0)
  timeLimitDays Int?

  users         User[]       @relation("UserLabel")
  processes     Process[]    @relation("ProcessLabel")
  automations   Automation[]

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model Automation {
  id             String   @id @default(cuid())
  name           String
  isActive       Boolean  @default(true)
  triggerLabelId String
  triggerLabel   Label    @relation(fields: [triggerLabelId], references: [id], onDelete: Cascade)
  cardType       String   @default("both")
  conditionLogic String   @default("AND")
  conditions     Json     @default("[]")
  actions        Json     @default("[]")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("automations")
}

model Comment {
  id         String   @id @default(cuid())
  text       String
  authorId   String?
  authorName String
  userId     String?
  processId  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  targetName String
  author     User?    @relation("CommentAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  process    Process? @relation("ProcessComments", fields: [processId], references: [id])
  user       User?    @relation("UserComments", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([processId])
  @@index([authorId])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model Message {
  id               String       @id @default(cuid())
  titulo           String
  role             String       @default("USER")
  createdAt        DateTime?    @default(now())
  updatedAt        DateTime?    @updatedAt
  multipleMessages SubMessage[]
}

model SubMessage {
  id        String    @id @default(cuid())
  conteudo  String
  messageId String
  mediaType String?
  mediaUrl  String?
  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt
  message   Message   @relation(fields: [messageId], references: [id], onDelete: Cascade)
}

model Document {
  id         String    @id @default(uuid())
  userId     String
  key        String
  name       String
  uploadedAt DateTime  @default(now())
  processId  String?
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt
  process    Process?  @relation(fields: [processId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Contact {
  id        String    @id @default(uuid())
  name      String
  number    String
  desc      String?
  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt
}

model Notification {
  id          String   @id @default(cuid())
  recipientId String
  authorId    String
  authorName  String
  message     String
  commentId   String?
  userId      String?
  processId   String?
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())
  targetName  String
  recipient   User     @relation("UserNotifications", fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([recipientId])
}

model Log {
  id         String   @id @default(cuid())
  // Tipo do evento: 'update' | 'move' | 'document_add' | 'document_remove' | 'comment_add' | 'create'
  action     String
  // Frase descritiva já pronta para exibir (ex.: "alterou o campo Telefone")
  message    String
  authorId   String
  authorName String
  // Card ao qual o log pertence — apenas um dos dois é preenchido.
  userId     String?
  processId  String?
  // Dados extras opcionais (campos alterados, de/para, nomes de documentos, etc.)
  metadata   Json?
  createdAt  DateTime @default(now())

  user       User?    @relation("UserLogs", fields: [userId], references: [id], onDelete: Cascade)
  process    Process? @relation("ProcessLogs", fields: [processId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([processId])
  @@map("logs")
}

model Botconversa {
  id        String    @id @default(cuid())
  nome      String
  evento    String
  telefone  String
  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt
}

model Discord {
  id        String    @id @default(cuid())
  message   String
  channelId String
  executeAt DateTime
  sent      Boolean   @default(false)
  nome      String?
  telefone  String?
  evento    String?
  hours     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt
  firstSent Boolean   @default(false)

  @@map("discord")
}

model WorkSession {
  id         String    @id @default(cuid())
  userId     String
  discordId  String
  date       String
  startedAt  DateTime?
  pausedAt   DateTime?
  resumedAt  DateTime?
  finishedAt DateTime?
  isActive   Boolean   @default(false)
  isPaused   Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([discordId, date])
}

model AdminChecklistItem {
  id        String   @id @default(cuid())
  processId String?
  userId    String?
  text      String
  checked   Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([processId])
  @@index([userId])
  @@map("admin_checklist_items")
}

model Instruction {
  id          String            @id @default(cuid())
  title       String
  description String?
  text        String?
  color       String            @default("amber")
  tags        String[]          @default([])
  folderName  String            @unique
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  files       InstructionFile[]

  @@map("instructions")
}

model InstructionFile {
  id            String      @id @default(cuid())
  instructionId String
  name          String
  key           String
  size          String?
  type          String?
  uploadedAt    DateTime    @default(now())
  instruction   Instruction @relation(fields: [instructionId], references: [id], onDelete: Cascade)

  @@index([instructionId])
  @@map("instruction_files")
}

